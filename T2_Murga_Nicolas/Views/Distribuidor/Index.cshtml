@model IEnumerable<T2_Murga_Nicolas.Models.Distribuidor>

@{
    ViewData["Title"] = "Lista de Distribuidores";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Mantenimiento de Distribuidores</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Distribuidor" asp-action="Crear" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Registrar Nuevo Distribuidor
            </a>
        </div>
    </div>
    <br />

    @if (Model.Count() > 0)
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Razón Social</th>
                    <th>Teléfono</th>
                    <th>Año Inicio</th>
                    <th>Contacto</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NombreDistribuidor</td>
                        <td>@item.RazonSocial</td>
                        <td>@item.Telefono</td>
                        <td>@item.AnioInicioOperacion</td>
                        <td>@item.Contacto</td>
                        <td class="text-center">
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Distribuidor" asp-action="Editar" asp-route-Id="@item.Id" class="btn btn-primary mx-2">
                                    Editar
                                </a>
                                <a asp-controller="Distribuidor" asp-action="Eliminar" asp-route-Id="@item.Id" class="btn btn-danger mx-2">
                                    Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No existen registros de distribuidores actualmente.</p>
    }
</div>