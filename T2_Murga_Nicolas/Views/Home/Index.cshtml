@{
    ViewData["Title"] = "Análisis de Distribuidores";
}

<div id="vista-distribuidor" style="padding: 20px; font-family: Arial, sans-serif;">
    </div>

<script>
    // Lee el parámetro de la URL (?empresa=...)
    var urlParams = new URLSearchParams(window.location.search);
    var seleccion = urlParams.get('empresa') || 'alicorp';

    var datos = {
        alicorp: {
            titulo: "Alicorp S.A.A. – Líder de Distribución Multicanal en el Perú",
            color: "#0d6efd",
            desc: "Alicorp es la empresa peruana de consumo masivo más grande a nivel nacional. Su estrategia destaca por un modelo integral de cadena de suministro que abastece de manera eficiente a múltiples canales: el canal tradicional (bodegas y mercados de abastos), el canal moderno (supermercados y tiendas de conveniencia) y el sector industrial. A través de macrocentros de distribución automatizados en Lima y sedes regionales, optimizan el picking y la distribución de última milla para garantizar el abastecimiento comercial.",
            img: "https://www.infobae.com/resizer/v2/OPS6VWYMMFHWTIDN263VISY4BI.jpeg?auth=9e4828b41b8bafb871b2a2805966b9a9712e9fab85ca2b4d60e9e2c0ec9b9c72&smart=true&width=1200&height=900&quality=85",
            video: "https://www.youtube.com/embed/Eor_Z9Fv8D0"
        },
        dhl: {
            titulo: "DHL Supply Chain – Operador Logístico Global",
            color: "#ffcc00",
            desc: "DHL Supply Chain es el mayor distribuidor y operador logístico del mundo. Se especializa en diseñar e implementar soluciones de distribución personalizadas para sectores clave como el automotriz, tecnológico, farmacéutico y retail, utilizando almacenes inteligentes interconectados globalmente para optimizar los tiempos de entrega.",
            img: "https://peruretail.sfo3.cdn.digitaloceanspaces.com/wp-content/uploads/WhatsApp-Image-2023-12-13-at-4.08.10-PM-2.jpeg",
            video: "https://www.youtube.com/embed/VZXCKBHAQbQ"
        },
        amazon: {
            titulo: "Amazon Logistics – Distribución Comercial y Última Milla",
            color: "#198754",
            desc: "Amazon Logistics represents la evolución de la distribución comercial mediante el uso intensivo de datos, inteligencia artificial y automatización robótica. Su modelo de distribución de última milla prioriza la velocidad de entrega extrema, gestionando almacenes inteligentes coordinados mediante algoritmos predictivos globales.",
            img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQT5hxrzPvR6G5kJzU4ialzaaHKeCkzsVAjjQ&s",
            video: "https://www.youtube.com/embed/5pTvd5BCdTE"
        }
    };

    var actual = datos[seleccion] || datos.alicorp;

    // Concatenación clásica de texto para evitar que el motor de Razor se rompa
    var htmlContent = '<h2 style="color: ' + actual.color + '; font-weight: bold; margin-bottom: 15px;">' + actual.titulo + '</h2>' +
                      '<p style="font-size: 16px; line-height: 1.6; text-align: justify; max-width: 900px;">' + actual.desc + '</p>' +
                      '<br />' +
                      '<img src="' + actual.img + '" alt="Distribución" style="border-radius: 8px; border: 1px solid #ccc; max-width: 100%; max-height: 350px;" />' +
                      '<br /><br />' +
                      '<h4 style="color: #333;">Video Institucional:</h4>' +
                      '<br />' +
                      '<iframe width="640" height="360" src="' + actual.video + '" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);"></iframe>';

    document.getElementById('vista-distribuidor').innerHTML = htmlContent;
</script>
